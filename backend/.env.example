# ===== Portfolio backend environment variables =====

# Server port
PORT=3000

# Allowed CORS origin (frontend served from same origin by default).
# When serving the frontend from this same server you can leave this as the server URL.
# For a separate dev frontend, set it to that origin, e.g. http://localhost:5173
CORS_ORIGIN=http://localhost:3000

# Session secret — use a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret

# Admin password hash (bcrypt). DO NOT store the plain password here.
# Generate a hash for your password with:  npm run hash -- "yourPassword"
# The example hash below corresponds to the password: admin123
ADMIN_PASSWORD_HASH=$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy

# Set to "production" behind HTTPS to enable secure cookies
NODE_ENV=development
